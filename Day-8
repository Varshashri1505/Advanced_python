#string compresion
x="AAACCDDDAAD"
res=" "
c=1
for i in range(len(x)):
    if i+1 < len(x) and x[i]==x[i+1]:#while using i+1 the i+1 value should be less than length of i
        c=c+1
    else:
        res=res+x[i]
        res=res+str(c)
        c=1
print(res)

#recurssion (backtracking)
def flower(a):
    if a==4:
        return
    print(a+10, end=" ")
    flower(a+1)
    print(a,end=" ")
flower(1)
