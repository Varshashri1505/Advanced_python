    for i in a:
        if i.isupper():
            up+=1
        elif i.islower():
            lc+=1
        elif i.isdigit():
            dg+=1
        else:
            sp+=1
    if up>0 and lc>0 and dg>0 and sp>0:
        print("STRONG PASSWORD")
    else:
        print("WEAK PASSWORD")
