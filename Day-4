    t=input("Enter the team name: ")
    teams.append(t)
m=int(input("Enter the number of meet between teams: "))

matches=[]
for i in range(0,a-1):
    for j in range(i+1,a):
        for k in range(m):
            matches.append([teams[i],teams[j]])

random.shuffle(matches)
pos=1
for i in matches:
    print("MATCH {} : {} vs {}".format(pos,i[0],i[1]))
